# Odoo backend — used ONLY by server routes under src/routes/api/**.
# Never expose these to the client (no PUBLIC_ prefix).
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-db
ODOO_USERNAME=you@example.com
ODOO_API_KEY=

# Web push. This MUST be Odoo's own VAPID public key, because Odoo signs the
# pushes it sends and the browser has to subscribe under the same key pair.
# Get it by calling, as admin:
#   mail.push.device -> get_web_push_vapid_public_key()
# (calling it also generates the pair on first use and stores it in
#  ir.config_parameter as mail.web_push_vapid_public_key / _private_key)
PUBLIC_VAPID_PUBLIC_KEY=

# Shared secret guarding /api/cron/schedule-reminders.
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
