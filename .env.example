# OPTIONAL — only needed if you wire the app to Odoo (see README).
# In the default local-storage mode none of these are required.
#
# Private — server-side only. NEVER prefix these with PUBLIC_ (that would leak
# them into the client bundle). Read via $env/static/private in +server.js.
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=your-username
ODOO_API_KEY=your-api-key
ODOO_MODEL=x_dailytracker

# Optional, PUBLIC (safe to expose). Only set when the static frontend is hosted
# separately from the server proxy. Empty => same-origin /api/odoo.
# PUBLIC_API_URL=https://your-proxy-host.vercel.app
# Optional, only for sub-path hosting like GitHub Pages.
# PUBLIC_BASE_PATH=/your-repo-name
