# Required. Private — server-side only. NEVER prefix with PUBLIC_ (that leaks
# them into the client bundle). Read via $env/dynamic/private in server routes.
#
# IMPORTANT: ODOO_USERNAME / ODOO_API_KEY are the ADMIN account used at signup to
# create a new company + user. This user must be an Odoo administrator (able to
# create res.company and res.users). After signup, each user's own session is
# used for all data — the admin key is never used for reading/writing trackers.
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=admin-username
ODOO_API_KEY=admin-api-key
ODOO_MODEL=x_dailytracker

# Password reset. The numeric id of an Odoo email template (mail.template) used
# to send the 6-digit reset code. Find it in Settings > Technical > Email
# Templates (Developer mode), or via the record URL (...id=NN...).
# The reset code is exposed to the template via render context, so reference it:
#   Subject (inline):   {{ ctx.get('reset_code') }}
#   Body  (qweb HTML):  <t t-out="ctx.get('reset_code')"/>
ODOO_RESET_TEMPLATE_ID=

# Web Push (VAPID). Generate keys once: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
# VAPID_PRIVATE_KEY is server-only. PUBLIC_VAPID_PUBLIC_KEY is exposed to the browser (safe — it's a public key).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com
PUBLIC_VAPID_PUBLIC_KEY=   # same value as VAPID_PUBLIC_KEY

# Native Push (FCM). Paste the full contents of your Firebase service account JSON
# as a single-line JSON string (or multi-line — just no bare newlines outside strings).
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Needed to send push notifications to iOS (APNs via FCM) and Android devices.
# Leave blank to disable native push (VAPID web push continues to work independently).
FIREBASE_SERVICE_ACCOUNT=

# Native Push — APNs direct (iOS, no Firebase required).
# APNS_KEY_P8: full content of the .p8 file downloaded from developer.apple.com → Keys.
# APNS_SANDBOX=true for debug/TestFlight builds; leave blank for App Store production.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_P8=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APNS_BUNDLE_ID=com.dailytracker.dailydeedtracker
APNS_SANDBOX=true

# Cron endpoint auth. Set this same random string in Vercel env vars.
CRON_SECRET=

# Optional, only for sub-path hosting like GitHub Pages.
# PUBLIC_BASE_PATH=/your-repo-name
